#!/data/data/com.termux/files/usr/bin/bash

WORKDIR="$HOME/MediaMatrix"
ENC_REPO="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2UycGhyZWFrZXIvbXlyZXBvL21haW4="
REPO=$(printf '%s' "$ENC_REPO" | base64 -d 2>/dev/null)

[ -z "$REPO" ] && {
    echo "Repo decode gagal"
    exit 1
}
LICENSE_FILE="$HOME/.mediamatrix_license"

validate_license() {
    LICENSE_URL="$REPO/licenses.json"

    [ ! -f "$LICENSE_FILE" ] && echo "❌ License tidak ditemukan" && exit 1

    USER_KEY=$(cat "$LICENSE_FILE")
    [ -z "$USER_KEY" ] && echo "❌ License kosong" && exit 1

    DATA=$(curl -s "$LICENSE_URL")
    [ -z "$DATA" ] && echo "❌ Tidak bisa konek ke server" && exit 1

    KEY_DATA=$(echo "$DATA" | grep -A5 "\"$USER_KEY\"")
    [ -z "$KEY_DATA" ] && echo "❌ License tidak valid" && exit 1
}

# 🔴 WAJIB DI SINI (SEBELUM APAPUN)
validate_license

# ==========================
# BARU SCRIPT UTAMA
# ==========================

echo "Reverse module jalan..."

WORKDIR="/sdcard/MediaMatrix"
mkdir -p "$WORKDIR"

# =========================
# VALIDATION TOOLS
# =========================
is_number() {
  [[ "$1" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

fix_decimal() {
  echo "$1" | sed 's/^\./0./'
}

# =========================
# DURATION PARSER (SMART INPUT)
# =========================
parse_target_duration() {
  local input="$1"
  local total_sec=0

  # Format HH:MM:SS atau MM:SS
  if [[ "$input" =~ ^([0-9]+):([0-9]{2}):([0-9]{2})$ ]]; then
    total_sec=$(( 10#${BASH_REMATCH[1]} * 3600 + 10#${BASH_REMATCH[2]} * 60 + 10#${BASH_REMATCH[3]} ))
  elif [[ "$input" =~ ^([0-9]+):([0-9]{2})$ ]]; then
    total_sec=$(( 10#${BASH_REMATCH[1]} * 60 + 10#${BASH_REMATCH[2]} ))
  
  # Format huruf (1h 30m 45s, 90m, 45s)
  else
    local h=0 m=0 s=0
    [[ "$input" =~ ([0-9]+)h ]] && h="${BASH_REMATCH[1]}"
    [[ "$input" =~ ([0-9]+)m ]] && m="${BASH_REMATCH[1]}"
    [[ "$input" =~ ([0-9]+)s? ]] && [[ ! "$input" =~ "m" && ! "$input" =~ "h" ]] && s="${BASH_REMATCH[1]}"
    [[ "$input" =~ ([0-9]+)s ]] && s="${BASH_REMATCH[1]}"
    
    total_sec=$(( h * 3600 + m * 60 + s ))
  fi

  # Fallback murni angka
  if [ "$total_sec" -eq 0 ] && is_number "$input"; then
    total_sec=$input
  fi

  echo "$total_sec"
}

# =========================
# SELECT FILE
# =========================
select_file() {
  while true; do
    echo ""
    echo "📂 Pilih file video:"
    echo ""

    mapfile -t FILE_LIST < <(find "$WORKDIR" -maxdepth 1 -type f \( -iname "*.mp4" -o -iname "*.mkv" -o -iname "*.mov" -o -iname "*.webm" -o -iname "*.avi" \))

    if [ ${#FILE_LIST[@]} -eq 0 ]; then
      echo "❌ Tidak ada file!"
      read -p "ENTER..."
      return 1
    fi

    for i in "${!FILE_LIST[@]}"; do
      echo "$((i+1))) $(basename "${FILE_LIST[$i]}")"
    done

    echo ""
    read -p "Pilih nomor: " num

    if ! [[ "$num" =~ ^[0-9]+$ ]]; then
      echo "❌ Harus angka"
      continue
    fi

    if [ "$num" -lt 1 ] || [ "$num" -gt "${#FILE_LIST[@]}" ]; then
      echo "❌ Nomor tidak tersedia"
      continue
    fi

    INPUT="${FILE_LIST[$((num-1))]}"

    if [ ! -f "$INPUT" ]; then
      echo "❌ File tidak valid"
      continue
    fi

    echo "✅ Dipilih: $(basename "$INPUT")"
    break
  done
}

# =========================
# MAIN LOOP
# =========================
while true; do

clear
echo "======================================"
echo " ⏪ ReverseMatrix Pro"
echo "======================================"
echo "📁 Workdir: $WORKDIR"
echo "1) 🔁 Reverse Engine"
echo "0) ❌ Keluar"
echo ""

read -p "Pilih menu: " menu

# =========================
# MENU 1 - REVERSE ENGINE
# =========================
if [ "$menu" = "1" ]; then

select_file || continue

# =========================
# GET NATIVE DURATION
# =========================
DURATION=$(ffprobe -v error -show_entries format=duration \
-of default=noprint_wrappers=1:nokey=1 "$INPUT")

if ! is_number "$DURATION"; then
  echo "❌ Gagal membaca durasi video asli"
  read -p "ENTER..."
  continue
fi

DURATION=$(fix_decimal "$DURATION")

echo ""
echo "Mode Reverse:"
echo "1) Classic Boomerang (Maju -> Mundur Full)"
echo "2) Overlapping Wave (Maju 3s -> Mundur 1.5s)"
echo "3) Rhythm Bounce (Maju 1.5s -> Mundur 1s)"
echo "4) Seamless Natural (Boomerang dengan Crossfade)"
echo "5) Custom Manual (Atur durasi maju mundur sendiri)"
read -p "Pilih: " mode

# =========================
# SETUP LOGIC BERDASARKAN MODE
# =========================
if [ "$mode" = "5" ]; then
  echo ""
  echo "========== MANUAL MODE =========="
  echo "Tips: Mundur (Backward) sebaiknya lebih kecil dari Maju (Forward)."
  echo ""
  
  read -p "Forward (detik maju): " FWD
  read -p "Backward (detik mundur): " BWD

  FWD=$(echo "$FWD" | tr -d '[:space:]')
  BWD=$(echo "$BWD" | tr -d '[:space:]')

  if ! is_number "$FWD"; then echo "❌ FWD invalid → default 3"; FWD=3; fi
  if ! is_number "$BWD"; then echo "❌ BWD invalid → default 1.5"; BWD=1.5; fi
elif [ "$mode" = "2" ]; then
  FWD=3.0
  BWD=1.5
elif [ "$mode" = "3" ]; then
  FWD=1.5
  BWD=1.0
fi

# =========================
# INPUT TARGET DURASI
# =========================
echo ""
echo "⏳ Target Durasi Output Video"
echo "Format yang didukung: 15 (detik), 1m 30s, 02:00, 1h"
read -p "Masukkan durasi target: " user_dur

TARGET_SEC=$(parse_target_duration "$user_dur")

if [ -z "$TARGET_SEC" ] || [ "$TARGET_SEC" -le 0 ]; then
  echo "❌ Format durasi tidak valid!"
  read -p "ENTER..."
  continue
fi

echo "✅ Target Durasi Akhir: $TARGET_SEC detik"

# =========================
# DYNAMIC FILTER BUILDER
# =========================
echo ""
echo "⚙️ Merakit filter matrix..."

FILTER=""
CONCAT=""
INDEX=0

if [ "$mode" = "1" ]; then
  # 1. BOOMERANG CLASSIC
  FILTER="[0:v]reverse[r];[0:v][r]concat=n=2:v=1:a=0[outv]"

elif [ "$mode" = "4" ]; then
  # 4. SEAMLESS NATURAL (CROSSFADE)
  FADE_DUR=1.5
  OFFSET=$(echo "$DURATION - $FADE_DUR" | bc -l)
  if (( $(echo "$OFFSET < 0" | bc -l) )); then OFFSET=0; fi

  FILTER="[0:v]split[fwd][rev_base]; \
[rev_base]reverse[rev]; \
[fwd][rev]xfade=transition=fade:duration=${FADE_DUR}:offset=${OFFSET}[outv]"

elif [ "$mode" = "2" ] || [ "$mode" = "3" ] || [ "$mode" = "5" ]; then
  # 2, 3, 5. OVERLAPPING / STUTTER / CUSTOM
  CUR=0

  while (( $(echo "$CUR < $DURATION" | bc -l) )); do
    # Maju
    END=$(echo "$CUR + $FWD" | bc -l)
    if (( $(echo "$END > $DURATION" | bc -l) )); then END=$DURATION; fi
    
    FILTER+="[0:v]trim=start=${CUR}:end=${END},setpts=PTS-STARTPTS[v${INDEX}f]; "
    CONCAT+="[v${INDEX}f]"
    
    # Mundur
    REV_START=$(echo "$END - $BWD" | bc -l)
    
    if (( $(echo "$REV_START > $CUR" | bc -l) )); then
      INDEX=$((INDEX+1))
      FILTER+="[0:v]trim=start=${REV_START}:end=${END},setpts=PTS-STARTPTS,reverse[v${INDEX}r]; "
      CONCAT+="[v${INDEX}r]"
      CUR=$REV_START
    else
      CUR=$END
    fi
    INDEX=$((INDEX+1))
  done

  FILTER+="${CONCAT}concat=n=${INDEX}:v=1:a=0[outv]"
else
  echo "❌ Mode tidak tersedia"
  read -p "ENTER..."
  continue
fi

# =========================
# OUTPUT NAMING SYSTEM
# =========================
DATE=$(date +%Y%m%d)
TIME=$(date +%H%M%S)

case $mode in
  1) OUT="$WORKDIR/rev_classic_${DATE}_${TIME}.mp4" ;;
  2) OUT="$WORKDIR/rev_wave_${DATE}_${TIME}.mp4" ;;
  3) OUT="$WORKDIR/rev_bounce_${DATE}_${TIME}.mp4" ;;
  4) OUT="$WORKDIR/rev_seamless_${DATE}_${TIME}.mp4" ;;
  5) OUT="$WORKDIR/rev_custom_${DATE}_${TIME}.mp4" ;;
esac

# =========================
# FFMPEG CORE
# =========================
echo "🎬 Processing Reverse Loop..."

ffmpeg -y -stream_loop -1 -i "$INPUT" \
  -filter_complex "$FILTER" \
  -map "[outv]" -an \
  -t "$TARGET_SEC" \
  -c:v libx264 -crf 20 -preset fast "$OUT"

# =========================
# RESULT CHECK
# =========================
echo ""
if [ -f "$OUT" ]; then
  echo "✅ Sukses"
  echo "📁 Output: $OUT"
else
  echo "❌ Gagal membuat file"
fi

read -p "ENTER..."
fi

# =========================
# EXIT
# =========================
if [ "$menu" = "0" ]; then
  break
fi

done