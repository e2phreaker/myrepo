#!/data/data/com.termux/files/usr/bin/bash

WORKDIR="$HOME/MediaMatrix"
ENC_REPO="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2UycGhyZWFrZXIvbXlyZXBvL21haW4="
REPO=$(echo "$ENC_REPO" | base64 -d)

LICENSE_FILE="$HOME/.mediamatrix_license"
VERSION_FILE="$WORKDIR/.version"
LOCAL_HASH_FILE="$WORKDIR/.hash"

# =========================
# LOAD VERSION
# =========================
VERSION="1.0"
[ -f "$VERSION_FILE" ] && VERSION=$(cat "$VERSION_FILE")

# =========================
# WARNA
# =========================
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
CYAN="\e[36m"
RESET="\e[0m"

# =========================
# LICENSE SYSTEM (FINAL)
# =========================
validate_license() {
    LICENSE_URL="$REPO/licenses.json"

    MAX_RETRY=3
    COUNT=0

    while true; do
        if [ -f "$LICENSE_FILE" ] && [ -s "$LICENSE_FILE" ]; then
            USER_KEY=$(cat "$LICENSE_FILE")
        else
            read -p "Masukkan license key: " USER_KEY
        fi

        [ -z "$USER_KEY" ] && echo "❌ License kosong!" && return 1

        DATA=$(curl -s "$LICENSE_URL")
        [ -z "$DATA" ] && echo "❌ Tidak bisa konek ke server" && return 1

        KEY_DATA=$(echo "$DATA" | grep -A5 "\"$USER_KEY\"")

        if [ -z "$KEY_DATA" ]; then
            echo "❌ License tidak valid"
            rm -f "$LICENSE_FILE"
        else
            STATUS=$(echo "$KEY_DATA" | grep status | cut -d '"' -f4)

            if [ "$STATUS" != "active" ]; then
                echo "🚫 License revoked"
                rm -f "$LICENSE_FILE"
            else
                echo "$USER_KEY" > "$LICENSE_FILE"
                break
            fi
        fi

        COUNT=$((COUNT+1))
        if [ "$COUNT" -ge "$MAX_RETRY" ]; then
            echo "❌ Gagal 3x. Coba lagi nanti."
            return 1
        fi
    done

    STATUS=$(echo "$KEY_DATA" | grep status | head -n1 | cut -d '"' -f4)
    EXPIRY=$(echo "$KEY_DATA" | grep expiry | head -n1 | cut -d '"' -f4)

    EXP_SEC=$(date -d "$EXPIRY" +%s)
    NOW_SEC=$(date +%s)
    DAYS_LEFT=$(( (EXP_SEC - NOW_SEC) / 86400 ))

    if [ "$DAYS_LEFT" -lt 0 ]; then
        echo "⛔ License expired ($EXPIRY)"
        return 1
    fi

    [ "$STATUS" != "active" ] && echo "🚫 License revoked" && return 1

    SERVER_DEVICE=$(echo "$KEY_DATA" | grep device | head -n1 | cut -d '"' -f4)

    if [ -z "$SERVER_DEVICE" ]; then
        DEVICE_ID=$(getprop ro.product.model 2>/dev/null)
        [ -z "$DEVICE_ID" ] && DEVICE_ID="unknown-device"

        echo "🔗 Device belum terdaftar"
        echo ""
        echo "📱 Device kamu: $DEVICE_ID"
        echo "🔑 License: $USER_KEY"
        echo ""
        echo "\"$USER_KEY\": {"
        echo "  \"expiry\": \"$EXPIRY\","
        echo "  \"status\": \"active\","
        echo "  \"device\": \"$DEVICE_ID\""
        echo "}"
        echo ""
        echo "👉 Hubungi Pengembang:"
        return 1
    fi

    LICENSE_INFO="🔓 License OK | Exp: $EXPIRY | ⏳ $DAYS_LEFT hari"
    return 0
}

# =========================
# AUTO UPDATE
# =========================
check_update() {
    echo ""
    echo "🔍 Mengecek update..."

    latest=$(curl -s "$REPO/version.txt")

    echo ""
    echo "📦 Versi lokal : $VERSION"
    echo "🌐 Versi terbaru: $latest"

    if [ "$latest" != "$VERSION" ]; then
        echo -e "${YELLOW}⚠️ Update tersedia!${RESET}"

        read -p "Update sekarang? (y/n): " confirm

        if [[ $confirm == "y" ]]; then
            echo "⬇️ Mengupdate..."

            cd "$WORKDIR" || exit

            curl -fLo audio "$REPO/audio"
            curl -fLo video "$REPO/video"
            curl -fLo yt "$REPO/yt"
            curl -fLo loop "$REPO/loop"
            curl -fLo matrix "$REPO/matrix"

            chmod +x audio video yt loop matrix

            echo "$latest" > "$VERSION_FILE"

            echo -e "${GREEN}✅ Update selesai${RESET}"
            echo "🔁 Jalankan ulang: matrix"
            exit 0
        fi
    else
        echo -e "${GREEN}✅ Sudah versi terbaru${RESET}"
    fi
}

# =========================
# START SYSTEM
# =========================
if ! validate_license; then
    echo "❌ License tidak valid"
    exit 1
fi

# =========================
# MENU
# =========================
draw_menu() {
    clear
    echo -e "${GREEN}$LICENSE_INFO${RESET}"
    echo ""
    echo -e "${CYAN}╔══════════════════════════════╗${RESET}"
    echo -e "${CYAN}║   🎛️ MediaMatrix Suite      ║${RESET}"
    echo -e "${CYAN}╠══════════════════════════════╣${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}1) 🎵 AudioMatrix Pro${RESET}      ${CYAN}║${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}2) 🎬 VideoMatrix Pro${RESET}      ${CYAN}║${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}3) 📺 StreamMatrix Pro${RESET}     ${CYAN}║${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}4) 🔁 LoopMatrix Pro${RESET}       ${CYAN}║${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}8) 🔑 Kelola License${RESET}     ${CYAN}║${RESET}"
    echo -e "${CYAN}║${RESET} ${YELLOW}9) 🔍 Cek Update${RESET}           ${CYAN}║${RESET}"
    echo -e "${CYAN}╠══════════════════════════════╣${RESET}"
    echo -e "${CYAN}║${RESET} ${RED}0) ❌ Keluar${RESET}                ${CYAN}║${RESET}"
    echo -e "${CYAN}╚══════════════════════════════╝${RESET}"
}

# =========================
# LOOP
# =========================
while true; do
    validate_license >/dev/null 2>&1
    draw_menu
    echo ""
    read -p "Pilih menu: " menu

    case $menu in
        1) clear; "$WORKDIR/audio" ;;
        2) clear; "$WORKDIR/video" ;;
        3) clear; "$WORKDIR/yt" ;;
        4) clear; "$WORKDIR/loop" ;;
        8)
    while true; do
        clear
        echo "🔐 Kelola License"
        echo "----------------------"
        echo "1) Ganti License"
        echo "2) Reset License"
        echo "0) Kembali"
        echo ""

        read -p "Pilih: " sub

        case $sub in
            1)
                clear
                echo "🔑 Ganti License"
                echo ""

                read -p "Masukkan license baru: " NEW_KEY

                if [ -z "$NEW_KEY" ]; then
                    echo "❌ License kosong!"
                    sleep 1
                    continue
                fi

                # hapus lama + simpan baru
                rm -f "$LICENSE_FILE"
                echo "$NEW_KEY" > "$LICENSE_FILE"

                echo ""
                echo "🔄 Validasi license..."

                if ! validate_license; then
                   echo "❌ License tidak valid"
                   rm -f "$LICENSE_FILE"
                   sleep 2
                   continue
                fi

                echo "✅ License berhasil diganti"
                sleep 1
                ;;
            
            2)
                clear
                echo "♻️ Reset License"
                echo ""

                rm -f "$LICENSE_FILE"

                echo "✅ License berhasil dihapus"
                echo "🔁 Jalankan ulang aplikasi untuk input license baru"
                sleep 2
                ;;
            
            0)
                break
                ;;
            
            *)
                echo "❌ Pilihan tidak valid"
                sleep 1
                ;;
        esac
    done
    ;;
        9)
            check_update
            echo ""
            read -p "ENTER untuk kembali..."
            ;;
        0)
            echo -e "${RED}Keluar...${RESET}"
            break
            ;;
        *)
            echo -e "${RED}❌ Pilihan tidak valid${RESET}"
            sleep 1
            ;;
    esac
done
