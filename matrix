#!/data/data/com.termux/files/usr/bin/bash

WORKDIR="$HOME/MediaMatrix"
ENC_REPO="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2UycGhyZWFrZXIvbXlyZXBvL21haW4="
REPO=$(printf '%s' "$ENC_REPO" | base64 -d 2>/dev/null)
[ -z "$REPO" ] && echo "❌ Repo decode gagal" && exit 1

LICENSE_FILE="$HOME/.mediamatrix_license"
VERSION_FILE="$WORKDIR/.version"
LOCAL_HASH_FILE="$WORKDIR/.hash"

VERSION_URL="$REPO/version.txt"
CHANGELOG_URL="$REPO/changelog.txt"
CHANGELOG_LATEST_URL="$REPO/changelog_latest.txt"

# =========================
# LOAD VERSION
# =========================
VERSION="1.0"
[ -f "$VERSION_FILE" ] && VERSION=$(cat "$VERSION_FILE")

# =========================
# WARNA
# =========================
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
CYAN="\e[36m"
RESET="\e[0m"

# =========================
# LICENSE SYSTEM (FINAL)
# =========================
validate_license() {
    LICENSE_URL="$REPO/licenses.json"

    MAX_RETRY=3
    COUNT=0

    while true; do
        if [ -f "$LICENSE_FILE" ] && [ -s "$LICENSE_FILE" ]; then
            USER_KEY=$(cat "$LICENSE_FILE")
            DISPLAY_KEY="$USER_KEY"
        else
            read -p "Masukkan license key: " USER_KEY
        fi

        [ -z "$USER_KEY" ] && echo "❌ License kosong!" && return 1

        DATA=$(curl -s "$LICENSE_URL")
        [ -z "$DATA" ] && echo "❌ Tidak bisa konek ke server" && return 1

        KEY_DATA=$(echo "$DATA" | awk "/\"$USER_KEY\"/,/}/")

        if [ -z "$KEY_DATA" ]; then
    echo "❌ License tidak valid"
    rm -f "$LICENSE_FILE"
else
    STATUS=$(echo "$KEY_DATA" | grep status | head -n1 | cut -d '"' -f4)

    if [ "$STATUS" != "active" ]; then
        echo "🚫 License revoked"
        rm -f "$LICENSE_FILE"
    else
        echo "$USER_KEY" > "$LICENSE_FILE"
        break
    fi
fi

        COUNT=$((COUNT+1))
        if [ "$COUNT" -ge "$MAX_RETRY" ]; then
            echo "❌ Gagal 3x. Coba lagi nanti."
            return 1
        fi
    done

    STATUS=$(echo "$KEY_DATA" | grep status | head -n1 | cut -d '"' -f4)
    EXPIRY=$(echo "$KEY_DATA" | grep expiry | head -n1 | cut -d '"' -f4)

    NOW_SEC=$(date +%s)

if [[ "$EXPIRY" == "lifetime" ]]; then
    DAYS_LEFT="∞"

elif [[ "$EXPIRY" == *d ]]; then
    # contoh: 30d
    DAYS=${EXPIRY%d}

    HASH_KEY=$(echo -n "$USER_KEY" | md5sum | cut -c1-8)
FIRST_USE_FILE="$WORKDIR/.lic_$HASH_KEY"

    if [ ! -f "$FIRST_USE_FILE" ]; then
    if [ -f "$WORKDIR/.installed" ]; then

        echo ""
        echo "===================================="
        echo "      TRIAL TIDAK VALID"
        echo "===================================="
        echo ""
        echo "❌ Trial tidak valid (reset terdeteksi)"
        echo ""
        echo "1. Hapus license"
        echo "2. Keluar"
        echo ""

        read -p "Pilih [1-2]: " MENU

        case "$MENU" in
            1)
                rm -f "$LICENSE_FILE"
                echo "✅ License berhasil dihapus."
                ;;
            2)
                ;;
        esac

        return 1
    fi

    date +%s > "$FIRST_USE_FILE"
    touch "$WORKDIR/.installed"
fi

    START=$(cat "$FIRST_USE_FILE")
    EXP_SEC=$((START + DAYS * 86400))
    DAYS_LEFT=$(( (EXP_SEC - NOW_SEC) / 86400 ))

else
    # format tanggal normal
    EXP_SEC=$(date -d "$EXPIRY" +%s 2>/dev/null)

    if [ -z "$EXP_SEC" ]; then
        echo "❌ Format expiry invalid"
        return 1
    fi

    DAYS_LEFT=$(( (EXP_SEC - NOW_SEC) / 86400 ))
fi

# =========================
# VALIDASI EXPIRED
# =========================
if [[ "$EXPIRY" != "lifetime" && "$NOW_SEC" -gt "$EXP_SEC" ]]; then

    clear
    echo "===================================="
    echo "      LICENSE EXPIRED"
    echo "===================================="
    echo ""
    echo "⛔ License expired ($EXPIRY)"
    echo ""
    echo "1. Hapus license"
    echo "2. Keluar"
    echo ""

    read -p "Pilih [1-2]: " MENU

    case "$MENU" in
        1)
            rm -f "$LICENSE_FILE"
            echo "✅ License berhasil dihapus."
            ;;
        2)
            ;;
        *)
            echo "❌ Pilihan tidak valid."
            ;;
    esac

    return 1
fi

    # ==========================================
    # MEMBUAT KODE UNIK HP (FINGERPRINT)
    # ==========================================
    MODEL=$(getprop ro.product.model 2>/dev/null | tr -d '[:space:]')
    BRAND=$(getprop ro.product.brand 2>/dev/null | tr -d '[:space:]')
    NET_ID=$(getprop net.hostname 2>/dev/null | cut -d'-' -f2)
    
    if [ -z "$NET_ID" ]; then
        NET_ID=$(ls -l /data/data/com.termux/files/home | awk '{print $3}' | md5sum | cut -c1-8)
    fi

    RAW_ID="${BRAND}-${MODEL}-${NET_ID}"
    DEVICE_ID=$(echo -n "$RAW_ID" | md5sum | cut -c1-8 | tr '[:lower:]' '[:upper:]')
    DEVICE_DISPLAY="${BRAND} ${MODEL} (${DEVICE_ID})"
    # ==========================================

    SERVER_DEVICE=$(echo "$KEY_DATA" | grep '"device"' | head -n1 | cut -d '"' -f4)

    # KONDISI A: Jika di server ternyata BELUM ada HP yang terdaftar (device masih "")
    if [ -z "$SERVER_DEVICE" ]; then
        echo "🔗 Device belum terdaftar"
        echo ""
        echo "📱 Device kamu: $DEVICE_DISPLAY"
        echo "🔑 License: $USER_KEY"
        echo ""
        echo "\"$USER_KEY\": {"
        echo "  \"expiry\": \"$EXPIRY\","
        echo "  \"status\": \"active\","
        echo "  \"device\": \"$DEVICE_ID\""
        echo "}"
        echo ""
        echo "👉 Hubungi Pengembang untuk mendaftarkan device ini."
        rm -f "$LICENSE_FILE"
        exit 1
    fi

    # KONDISI B: Jika di server SUDAH ADA, cocokkan Kode Uniknya
    if [ "$SERVER_DEVICE" != "$DEVICE_ID" ]; then
        clear
        echo "===================================="
        echo "      AKSES DITOLAK (DEVICE SALAH)  "
        echo "===================================="
        echo ""
        echo "❌ Lisensi ini sudah dipakai di HP lain!"
        echo "📱 ID Terdaftar : $SERVER_DEVICE"
        echo "📲 ID HP Kamu   : $DEVICE_ID ($DEVICE_DISPLAY)"
        echo ""
        echo "👉 Silakan gunakan lisensi lain atau hubungi pengembang."
        rm -f "$LICENSE_FILE"
        exit 1
    fi

    if [[ "$EXPIRY" == "lifetime" ]]; then
    LICENSE_INFO="🔓 Lifetime License ♾"
elif [[ "$EXPIRY" == *d ]]; then
    LICENSE_INFO="🔓 Trial License | ⏳ $DAYS_LEFT hari"
else
    LICENSE_INFO="🔓 License OK | Exp: $EXPIRY | ⏳ $DAYS_LEFT hari"
fi
    return 0
}

# =========================
# AUTO UPDATE
# =========================
check_update() {
    echo ""
    echo "🔍 Mengecek update..."

    latest=$(curl -s "$REPO/version.txt")

    echo ""
    echo "📦 Versi lokal : $VERSION"
    echo "🌐 Versi terbaru: $latest"

    if [ "$latest" != "$VERSION" ]; then
        echo -e "${YELLOW}⚠️ Update tersedia!${RESET}"

        echo ""
        echo "========== UPDATE TERBARU =========="
        curl -fsSL "$CHANGELOG_LATEST_URL"
        echo "==============================="
        echo ""

        read -p "Update sekarang? (y/n): " confirm

        if [[ $confirm =~ ^[Yy]$ ]]; then

            echo "⬇️ Mengupdate & Mengenkripsi..."

            cd "$WORKDIR" || exit

            # Download versi terbaru sebagai file mentah sementara
            curl -fLo .matrix_raw "$REPO/matrix"

            # Enkripsi ulang menggunakan SHC di HP user
            shc -f .matrix_raw -o matrix
            
            # Bersihkan file sampah
            rm -f .matrix_raw .matrix_raw.x.c

            chmod +x matrix

            echo "$latest" > "$VERSION_FILE"

            echo -e "${GREEN}✅ Update & Enkripsi selesai${RESET}"
            echo "🔁 Jalankan ulang: matrix"
            exit 0
        fi
    else
        echo -e "${GREEN}✅ Sudah versi terbaru${RESET}"
    fi
}

view_changelog() {

    clear

    echo "========== CHANGELOG =========="
    echo ""

    curl -fsSL "$CHANGELOG_URL"

    echo ""
}

# =========================
# START SYSTEM
# =========================
if ! validate_license; then
    echo "❌ License tidak valid"
    exit 1
fi

# =========================
# MENU
# =========================
draw_menu() {
draw_menu() {
    clear
    echo -e "${GREEN}● $LICENSE_INFO${RESET}"
    echo -e "${CYAN}========================================================${RESET}"
    echo -e "                 MEDIAMATRIX SUITE PRO              "
    echo -e "             ${YELLOW}v${VERSION}${RESET} | Powered by Premium Engine"
    echo -e "${CYAN}========================================================${RESET}"
    echo -e " 👤 Developer : Asep Rianto"
    echo -e " 📱 Perangkat  : ${DEVICE_DISPLAY:-Unknown}"
    echo -e "${CYAN}--------------------------------------------------------${RESET}"
    # Formasi Simetris: 5 Menu di Kiri & 4 Menu di Kanan (Pas Berpasangan)
    echo -e "  ${CYAN}[1]${RESET} AudioMatrix Pro      ${CYAN}[6]${RESET} PongMatrix Pro"
    echo -e "  ${CYAN}[2]${RESET} VideoMatrix Pro      ${CYAN}[7]${RESET} Kelola License"
    echo -e "  ${CYAN}[3]${RESET} FetchMatrix Pro      ${CYAN}[8]${RESET} Lihat Changelog"
    echo -e "  ${CYAN}[4]${RESET} LoopMatrix Pro       ${CYAN}[9]${RESET} Cek Pembaruan"
    echo -e "  ${CYAN}[5]${RESET} StreamMatrix Pro"
    echo -e "${CYAN}--------------------------------------------------------${RESET}"
    echo -e "  ${RED}[0] Keluar Aplikasi${RESET}"
    echo -e "${CYAN}========================================================${RESET}"
}

# =========================
# LOOP
# =========================
while true; do
    if ! validate_license; then
        sleep 1
        continue
    fi

    draw_menu
    echo ""
    read -p "Pilih menu: " menu

    case $menu in
        1)
            clear
            TMP_RAW="$WORKDIR/.audio_raw"
            TMP_BIN="$WORKDIR/.audio"
            echo "⬇️ Downloading & Encrypting AudioMatrix..."
            curl -fsSL "$REPO/audio" -o "$TMP_RAW" || {
                echo "❌ Gagal download AudioMatrix."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        2)
            clear
            TMP_RAW="$WORKDIR/.video_raw"
            TMP_BIN="$WORKDIR/.video"
            echo "⬇️ Downloading & Encrypting VideoMatrix..."
            curl -fsSL "$REPO/video" -o "$TMP_RAW" || {
                echo "❌ Gagal download VideoMatrix."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        3)
            clear
            TMP_RAW="$WORKDIR/.yt_raw"
            TMP_BIN="$WORKDIR/.yt"
            echo "⬇️ Downloading & Encrypting FetchMatrix..."
            curl -fsSL "$REPO/yt" -o "$TMP_RAW" || {
                echo "❌ Gagal download FetchMatrix."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        4)
            clear
            TMP_RAW="$WORKDIR/.loop_raw"
            TMP_BIN="$WORKDIR/.loop"
            echo "⬇️ Downloading & Encrypting LoopMatrix..."
            curl -fsSL "$REPO/loop" -o "$TMP_RAW" || {
                echo "❌ Gagal download LoopMatrix."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        5)
            clear
            TMP_RAW="$WORKDIR/.live_raw"
            TMP_BIN="$WORKDIR/.live"
            echo "⬇️ Downloading & Encrypting StreamMatrix..."
            curl -fsSL "$REPO/live" -o "$TMP_RAW" || {
                echo "❌ Gagal download StreamMatrix."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        6)
            clear
            TMP_RAW="$WORKDIR/.pong_raw"
            TMP_BIN="$WORKDIR/.pong"
            echo "⬇️ Downloading & Encrypting PongMatrix Pro..."
            curl -fsSL "$REPO/pong" -o "$TMP_RAW" || {
                echo "❌ Gagal download PongMatrix Pro."
                read -p "ENTER..."
                break
            }
            shc -f "$TMP_RAW" -o "$TMP_BIN"
            rm -f "$TMP_RAW" "$TMP_RAW.x.c"
            chmod +x "$TMP_BIN"
            "$TMP_BIN"
            rm -f "$TMP_BIN"
            ;;
        7)
            while true; do
                clear
                # Ambil data lisensi lokal untuk ditampilkan
                CURRENT_KEY="Belum ada / Kosong"
                [ -f "$LICENSE_FILE" ] && CURRENT_KEY=$(cat "$LICENSE_FILE")

                echo "========================================="
                echo "         INFORMASI LISENSI KAMU          "
                echo "========================================="
                echo "🔑 License Key : $CURRENT_KEY"
                echo "⏳ Expiry      : ${EXPIRY:-Tidak diketahui/Belum cek}"
                echo "🟢 Status      : ${STATUS:-Tidak aktif}"
                echo "📱 Device ID   : ${DEVICE_ID:-Belum terdaftar}"
                echo "========================================="
                echo "⚙️ PILIHAN MANAJEMEN:"
                echo "1) Ganti License (Input Key Baru)"
                echo "2) Reset / Hapus License Dari HP"
                echo "0) Kembali ke Menu Utama"
                echo "========================================="
                echo ""
                read -p "Pilihan Kamu [0-2]: " LIC_CHOOSE

            case $LIC_CHOOSE in
            1)
                clear
                echo "🔑 Ganti License"
                echo ""

                read -p "Masukkan license baru: " NEW_KEY

                if [ -z "$NEW_KEY" ]; then
                    echo "❌ License kosong!"
                    sleep 1
                    continue
                fi

                # hapus lama + simpan baru
                rm -f "$LICENSE_FILE"
                echo "$NEW_KEY" > "$LICENSE_FILE"

                echo ""
                echo "🔄 Validasi license..."

                if ! validate_license; then
                   echo "❌ License tidak valid"
                   rm -f "$LICENSE_FILE"
                   sleep 2
                   continue
                fi

                echo "✅ License berhasil diganti"
                sleep 1
                ;;
            
            2)
                clear
                echo "♻️ Reset License"
                echo ""

                rm -f "$LICENSE_FILE"

                echo "✅ License berhasil dihapus"
                echo "🔁 Jalankan ulang aplikasi untuk input license baru"
                sleep 2
                ;;
            
            0)
                break
                ;;
            
            *)
                echo "❌ Pilihan tidak valid"
                sleep 1
                ;;
        esac
    done
    ;;
        8)
            view_changelog
            read -p "ENTER untuk kembali..."
            ;;
        9)
            check_update
            echo ""
            read -p "ENTER untuk kembali..."
            ;;
        0)
            echo -e "${RED}Keluar...${RESET}"
            break
            ;;
        *)
            echo -e "${RED}❌ Pilihan tidak valid${RESET}"
            sleep 1
            ;;
    esac
done
