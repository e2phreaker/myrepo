#!/data/data/com.termux/files/usr/bin/bash

WORKDIR="$HOME/MediaMatrix"
ENC_REPO="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2UycGhyZWFrZXIvbXlyZXBvL21haW4="
REPO=$(printf '%s' "$ENC_REPO" | base64 -d 2>/dev/null)
[ -z "$REPO" ] && echo "вќЊ Repo decode gagal" && exit 1

LICENSE_FILE="$HOME/.mediamatrix_license"
VERSION_FILE="$WORKDIR/.version"
LOCAL_HASH_FILE="$WORKDIR/.hash"

VERSION_URL="$REPO/version.txt"
CHANGELOG_URL="$REPO/changelog.txt"
CHANGELOG_LATEST_URL="$REPO/changelog_latest.txt"

# =========================
# LOAD VERSION
# =========================
VERSION="1.0"
[ -f "$VERSION_FILE" ] && VERSION=$(cat "$VERSION_FILE")

# =========================
# WARNA
# =========================
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
CYAN="\e[36m"
RESET="\e[0m"

# =========================
# LICENSE SYSTEM (FINAL)
# =========================
validate_license() {
    LICENSE_URL="$REPO/licenses.json"

    MAX_RETRY=3
    COUNT=0

    while true; do
        if [ -f "$LICENSE_FILE" ] && [ -s "$LICENSE_FILE" ]; then
            USER_KEY=$(cat "$LICENSE_FILE")
            DISPLAY_KEY="$USER_KEY"
        else
            read -p "Masukkan license key: " USER_KEY
        fi

        [ -z "$USER_KEY" ] && echo "вќЊ License kosong!" && return 1

        DATA=$(curl -s "$LICENSE_URL")
        [ -z "$DATA" ] && echo "вќЊ Tidak bisa konek ke server" && return 1

        KEY_DATA=$(echo "$DATA" | awk "/\"$USER_KEY\"/,/}/")

        if [ -z "$KEY_DATA" ]; then
    echo "вќЊ License tidak valid"
    rm -f "$LICENSE_FILE"
else
    STATUS=$(echo "$KEY_DATA" | grep status | head -n1 | cut -d '"' -f4)

    if [ "$STATUS" != "active" ]; then
        echo "рџљ« License revoked"
        rm -f "$LICENSE_FILE"
    else
        echo "$USER_KEY" > "$LICENSE_FILE"
        break
    fi
fi

        COUNT=$((COUNT+1))
        if [ "$COUNT" -ge "$MAX_RETRY" ]; then
            echo "вќЊ Gagal 3x. Coba lagi nanti."
            return 1
        fi
    done

    STATUS=$(echo "$KEY_DATA" | grep status | head -n1 | cut -d '"' -f4)
    EXPIRY=$(echo "$KEY_DATA" | grep expiry | head -n1 | cut -d '"' -f4)

    NOW_SEC=$(date +%s)

if [[ "$EXPIRY" == "lifetime" ]]; then
    DAYS_LEFT="в€ћ"

elif [[ "$EXPIRY" == *d ]]; then
    # contoh: 30d
    DAYS=${EXPIRY%d}

    HASH_KEY=$(echo -n "$USER_KEY" | md5sum | cut -c1-8)
FIRST_USE_FILE="$WORKDIR/.lic_$HASH_KEY"

    if [ ! -f "$FIRST_USE_FILE" ]; then
    if [ -f "$WORKDIR/.installed" ]; then

        echo ""
        echo "===================================="
        echo "      TRIAL TIDAK VALID"
        echo "===================================="
        echo ""
        echo "вќЊ Trial tidak valid (reset terdeteksi)"
        echo ""
        echo "1. Hapus license"
        echo "2. Keluar"
        echo ""

        read -p "Pilih [1-2]: " MENU

        case "$MENU" in
            1)
                rm -f "$LICENSE_FILE"
                echo "вњ… License berhasil dihapus."
                ;;
            2)
                ;;
        esac

        return 1
    fi

    date +%s > "$FIRST_USE_FILE"
    touch "$WORKDIR/.installed"
fi

    START=$(cat "$FIRST_USE_FILE")
    EXP_SEC=$((START + DAYS * 86400))
    DAYS_LEFT=$(( (EXP_SEC - NOW_SEC) / 86400 ))

else
    # format tanggal normal
    EXP_SEC=$(date -d "$EXPIRY" +%s 2>/dev/null)

    if [ -z "$EXP_SEC" ]; then
        echo "вќЊ Format expiry invalid"
        return 1
    fi

    DAYS_LEFT=$(( (EXP_SEC - NOW_SEC) / 86400 ))
fi

# =========================
# VALIDASI EXPIRED
# =========================
if [[ "$EXPIRY" != "lifetime" && "$NOW_SEC" -gt "$EXP_SEC" ]]; then

    clear
    echo "===================================="
    echo "      LICENSE EXPIRED"
    echo "===================================="
    echo ""
    echo "в›” License expired ($EXPIRY)"
    echo ""
    echo "1. Hapus license"
    echo "2. Keluar"
    echo ""

    read -p "Pilih [1-2]: " MENU

    case "$MENU" in
        1)
            rm -f "$LICENSE_FILE"
            echo "вњ… License berhasil dihapus."
            ;;
        2)
            ;;
        *)
            echo "вќЊ Pilihan tidak valid."
            ;;
    esac

    return 1
fi

    # ==========================================
    # MEMBUAT KODE UNIK HP (FINGERPRINT)
    # ==========================================
    MODEL=$(getprop ro.product.model 2>/dev/null | tr -d '[:space:]')
    BRAND=$(getprop ro.product.brand 2>/dev/null | tr -d '[:space:]')
    NET_ID=$(getprop net.hostname 2>/dev/null | cut -d'-' -f2)
    
    if [ -z "$NET_ID" ]; then
        NET_ID=$(ls -l /data/data/com.termux/files/home | awk '{print $3}' | md5sum | cut -c1-8)
    fi

    RAW_ID="${BRAND}-${MODEL}-${NET_ID}"
    DEVICE_ID=$(echo -n "$RAW_ID" | md5sum | cut -c1-8 | tr '[:lower:]' '[:upper:]')
    DEVICE_DISPLAY="${BRAND} ${MODEL} (${DEVICE_ID})"
    # ==========================================

    SERVER_DEVICE=$(echo "$KEY_DATA" | grep '"device"' | head -n1 | cut -d '"' -f4)

    # KONDISI A: Jika di server ternyata BELUM ada HP yang terdaftar (device masih "")
    if [ -z "$SERVER_DEVICE" ]; then
        echo "рџ”— Device belum terdaftar"
        echo ""
        echo "рџ“± Device kamu: $DEVICE_DISPLAY"
        echo "рџ”‘ License: $USER_KEY"
        echo ""
        echo "\"$USER_KEY\": {"
        echo "  \"expiry\": \"$EXPIRY\","
        echo "  \"status\": \"active\","
        echo "  \"device\": \"$DEVICE_ID\""
        echo "}"
        echo ""
        echo "рџ‘‰ Hubungi Pengembang untuk mendaftarkan device ini."
        rm -f "$LICENSE_FILE"
        exit 1
    fi

    # KONDISI B: Jika di server SUDAH ADA, cocokkan Kode Uniknya
    if [ "$SERVER_DEVICE" != "$DEVICE_ID" ]; then
        clear
        echo "===================================="
        echo "      AKSES DITOLAK (DEVICE SALAH)  "
        echo "===================================="
        echo ""
        echo "вќЊ Lisensi ini sudah dipakai di HP lain!"
        echo "рџ“± ID Terdaftar : $SERVER_DEVICE"
        echo "рџ“І ID HP Kamu   : $DEVICE_ID ($DEVICE_DISPLAY)"
        echo ""
        echo "рџ‘‰ Silakan gunakan lisensi lain atau hubungi pengembang."
        rm -f "$LICENSE_FILE"
        exit 1
    fi

    if [[ "$EXPIRY" == "lifetime" ]]; then
    LICENSE_INFO="рџ”“ Lifetime License в™ѕ"
elif [[ "$EXPIRY" == *d ]]; then
    LICENSE_INFO="рџ”“ Trial License | вЏі $DAYS_LEFT hari"
else
    LICENSE_INFO="рџ”“ License OK | Exp: $EXPIRY | вЏі $DAYS_LEFT hari"
fi
    return 0
}

# =========================
# AUTO UPDATE
# =========================
check_update() {
    echo ""
    echo "рџ”Ќ Mengecek update..."

    latest=$(curl -s "$REPO/version.txt")

    echo ""
    echo "рџ“¦ Versi lokal : $VERSION"
    echo "рџЊђ Versi terbaru: $latest"

    if [ "$latest" != "$VERSION" ]; then
        echo -e "${YELLOW}вљ пёЏ Update tersedia!${RESET}"

        echo ""
        echo "========== UPDATE TERBARU =========="
        curl -fsSL "$CHANGELOG_LATEST_URL"
        echo "==============================="
        echo ""

        read -p "Update sekarang? (y/n): " confirm

        if [[ $confirm =~ ^[Yy]$ ]]; then

            echo "в¬‡пёЏ Mengupdate & Mengenkripsi..."

            cd "$WORKDIR" || exit

            # Download versi terbaru sebagai file mentah sementara
            curl -fLo .matrix_raw "$REPO/matrix"

            # Enkripsi ulang menggunakan SHC di HP user
            shc -f .matrix_raw -o matrix
            
            # Bersihkan file sampah
            rm -f .matrix_raw .matrix_raw.x.c

            chmod +x matrix

            echo "$latest" > "$VERSION_FILE"

            echo -e "${GREEN}вњ… Update & Enkripsi selesai${RESET}"
            echo "рџ”Ѓ Jalankan ulang: matrix"
            exit 0
        fi
    else
        echo -e "${GREEN}вњ… Sudah versi terbaru${RESET}"
    fi
}

view_changelog() {

    clear

    echo "========== CHANGELOG =========="
    echo ""

    curl -fsSL "$CHANGELOG_URL"

    echo ""
}

# =========================
# START SYSTEM
# =========================
if ! validate_license; then
