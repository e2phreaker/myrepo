        if [ "$m_engine" = "1" ]; then
    # --- MODE 1: DIRECT COPY (DIPERBAIKI) ---
    # 1. Cek sample rate
    sr=$(ffprobe -v error -select_streams a:0 -show_entries stream=sample_rate -of default=noprint_wrappers=1:nokey=1 "$infile")
    # 2. Cek channel
