#!/data/data/com.termux/files/usr/bin/bash

WORKDIR="$HOME/MediaMatrix"
ENC_REPO="aHR0cHM6Ly9yYXcuZ2l0aHVidXNlcmNvbnRlbnQuY29tL2UycGhyZWFrZXIvbXlyZXBvL21haW4="
REPO=$(printf '%s' "$ENC_REPO" | base64 -d 2>/dev/null)

[ -z "$REPO" ] && {
    echo "Repo decode gagal"
    exit 1
}
LICENSE_FILE="$HOME/.mediamatrix_license"

validate_license() {
    LICENSE_URL="$REPO/licenses.json"

    [ ! -f "$LICENSE_FILE" ] && echo "❌ License tidak ditemukan" && exit 1

    USER_KEY=$(cat "$LICENSE_FILE")
    [ -z "$USER_KEY" ] && echo "❌ License kosong" && exit 1

    DATA=$(curl -s "$LICENSE_URL")
    [ -z "$DATA" ] && echo "❌ Tidak bisa konek ke server" && exit 1

    KEY_DATA=$(echo "$DATA" | grep -A5 "\"$USER_KEY\"")
    [ -z "$KEY_DATA" ] && echo "❌ License tidak valid" && exit 1
}

# 🔴 WAJIB DI SINI (SEBELUM APAPUN)
validate_license

# ==========================
# BARU SCRIPT UTAMA
# ==========================

echo "Audio module jalan..."

WORKDIR="/sdcard/MediaMatrix"
mkdir -p "$WORKDIR"

PROGRESS_OPT=(
  --newline
  --progress
  --console-title
  --progress-template $'\e[1;32m[%(progress._percent_str)s]\e[0m \e[1;34m%(progress._downloaded_bytes_str)s/%(progress._total_bytes_str)s\e[0m • \e[1;33m%(progress._speed_str)s\e[0m • ETA \e[1;31m%(progress._eta_str)s\e[0m'
)

# =========================
# MODULAR YT-DLP
# =========================

run_yt() {
  yt-dlp -f "$FORMAT_VIDEO" \
  --merge-output-format "$MERGE" \
  $THUMB_OPT $META_OPT "${PROGRESS_OPT[@]}" \
  -o "$WORKDIR/%(title).80s [%(id)s].%(ext)s" "$@"
}

run_audio() {
  yt-dlp -x --audio-format "$AFORMAT" \
  $THUMB_OPT $META_OPT "${PROGRESS_OPT[@]}" \
  -o "$WORKDIR/%(title).80s [%(id)s].%(ext)s" "$@"
}

run_thumb() {
  if [ "$THUMB_SELECT" = "all" ]; then
    yt-dlp --write-all-thumbnails $FORMAT_OPT --skip-download \
    "${PROGRESS_OPT[@]}" \
    -o "$WORKDIR/%(title).80s [%(id)s].%(ext)s" "$@"
  else
    yt-dlp --write-thumbnail $FORMAT_OPT --skip-download \
    "${PROGRESS_OPT[@]}" \
    -o "$WORKDIR/%(title).80s [%(id)s].%(ext)s" "$@"
  fi
}

while true; do
  clear
  echo "=============================="
  echo "   📥 FetchMatrix Pro"
  echo "=============================="
  echo ""
  echo "1) 🎬 Download Video"
  echo "2) 🎧 Download Audio"
  echo "3) 🖼️ Thumbnail Downloader"
  echo "4) 🌐 Platform Support"
  echo "5) 🔍 Cek Link"
  echo "6) 🔄 Update yt-dlp"
  echo "0) ❌ Keluar"
  echo ""

  read -p "Pilih menu: " menu

  case $menu in

  # =========================
  # DOWNLOAD VIDEO
  # =========================
  1)
    echo ""
    echo "Pilih input:"
    echo "1) Link langsung"
    echo "2) File list (list.txt)"
    read -p "Pilihan: " input

    echo ""
    echo "Pilih resolusi:"
    echo "1) 720p"
    echo "2) 1080p"
    echo "3) 1440p (2K)"
    echo "4) 2160p (4K)"
    read -p "Pilihan: " res

    case $res in
      1) RES="720" ;;
      2) RES="1080" ;;
      3) RES="1440" ;;
      4) RES="2160" ;;
      *) RES="720" ;;
    esac

    echo ""
    echo "Pilih format:"
    echo "1) Kualitas Terbaik"
    echo "2) MP4"
    echo "3) MKV"
    echo "4) WEBM"
    read -p "Pilihan: " fmt

    case $fmt in
      1)
        FORMAT_VIDEO="bestvideo[height<=${RES}]+bestaudio/best[height<=${RES}]"
        MERGE="mkv"
        ;;
      2)
        FORMAT_VIDEO="bestvideo[ext=mp4][height<=${RES}]+bestaudio[ext=m4a]/best"
        MERGE="mp4/mkv"
        ;;
      3)
        FORMAT_VIDEO="bestvideo[height<=${RES}]+bestaudio/best"
        MERGE="mkv"
        ;;
      4)
        FORMAT_VIDEO="bestvideo[ext=webm][height<=${RES}]+bestaudio[ext=webm]/best"
        MERGE="webm/mkv"
        ;;
    esac

    # ===== THUMBNAIL =====
    echo ""
    echo "Download thumbnail?"
    echo "1) Ya"
    echo "2) Tidak"
    read -p "Pilih: " thumb

    if [ "$thumb" = "1" ]; then
      THUMB_OPT="--write-thumbnail --convert-thumbnails jpg --embed-thumbnail"
    else
      THUMB_OPT=""
    fi

    META_OPT="--embed-metadata"

    echo ""
    if [ "$input" = "1" ]; then
      read -p "Masukkan link: " URL
      run_yt "$URL"
    else
      read -p "Masukkan file list: " FILE

      FILE="$WORKDIR/$FILE"

      if [ ! -f "$FILE" ]; then
          echo "❌ File tidak ditemukan: $FILE"
          exit 1
      fi

      while read -r line; do
          echo "Processing: $line"
      done < "$FILE"
      run_yt -a "$FILE"
    fi

    read -p "ENTER untuk kembali..."
    ;;

  # =========================
  # DOWNLOAD AUDIO
  # =========================
  2)
    echo ""
    echo "Pilih input:"
    echo "1) Link langsung"
    echo "2) File list"
    read -p "Pilihan: " input

    echo ""
    echo "Format audio:"
    echo "1) mp3"
    echo "2) m4a"
    echo "3) wav"
    echo "4) flac"
    read -p "Pilihan: " afmt

    case $afmt in
      1) AFORMAT="mp3" ;;
      2) AFORMAT="m4a" ;;
      3) AFORMAT="wav" ;;
      4) AFORMAT="flac" ;;
      *) AFORMAT="mp3" ;;
    esac

    # ===== THUMBNAIL =====
    echo ""
    echo "Download thumbnail?"
    echo "1) Ya (embed + file)"
    echo "2) Tidak"
    read -p "Pilih: " thumb

    if [ "$thumb" = "1" ]; then
      THUMB_OPT="--write-thumbnail --convert-thumbnails jpg --embed-thumbnail"
    else
      THUMB_OPT=""
    fi

    META_OPT="--embed-metadata"

    echo ""
    if [ "$input" = "1" ]; then
      read -p "Masukkan link: " URL
      run_audio "$URL"
    else
      read -p "Masukkan file list: " FILE
      run_audio -a "$FILE"
    fi

    read -p "ENTER untuk kembali..."
    ;;

  # =========================
  # THUMBNAIL DOWNLOADER
  # =========================
  3)
  clear
  echo "=============================="
  echo " 🖼️ THUMBNAIL DOWNLOADER"
  echo "=============================="
  echo ""

  read -p "Masukkan URL: " URL

  echo ""
  echo "Pilih kualitas thumbnail:"
  echo "1) Best (Auto)"
  echo "2) Max Resolution"
  echo "3) High"
  echo "4) Medium"
  echo "5) Low"
  echo "6) Semua thumbnail"
  read -p "Pilih: " tq

  case $tq in
    1) THUMB_SELECT="best" ;;
    2) THUMB_SELECT="maxres" ;;
    3) THUMB_SELECT="hq" ;;
    4) THUMB_SELECT="mq" ;;
    5) THUMB_SELECT="low" ;;
    6) THUMB_SELECT="all" ;;
    *) THUMB_SELECT="best" ;;
  esac

  echo ""
  echo "Pilih format:"
  echo "1) JPG (recommended)"
  echo "2) WEBP"
  echo "3) Original"
  read -p "Pilih: " tf

  case $tf in
    1) FORMAT_OPT="--convert-thumbnails jpg" ;;
    2) FORMAT_OPT="--convert-thumbnails webp" ;;
    3) FORMAT_OPT="" ;;
    *) FORMAT_OPT="--convert-thumbnails jpg" ;;
  esac

  echo ""
  echo "📥 Downloading thumbnail..."

  if [ "$THUMB_SELECT" = "all" ]; then
    run_thumb "$URL"
  else
    run_thumb "$URL"
  fi

  echo ""
  echo "✅ Selesai download thumbnail"
  read -p "ENTER untuk kembali..."
  ;;

  4)
  clear
  echo "=============================="
  echo "   PLATFORM SUPPORT"
  echo "=============================="
  echo ""

  echo "🎬 Video Platforms:"
  echo "- YouTube"
  echo "- Vimeo"
  echo "- Dailymotion"
  echo "- Facebook"
  echo "- Instagram"
  echo "- TikTok"
  echo "- Twitter (X)"
  echo ""

  echo "🎧 Audio Platforms:"
  echo "- SoundCloud"
  echo "- Bandcamp"
  echo "- Mixcloud"
  echo "- Audiomack"
  echo "- HearThis.at"
  echo ""

  echo "📺 Streaming / Live:"
  echo "- Twitch"
  echo "- Kick"
  echo "- YouTube Live"
  echo "- Facebook Live"
  echo "- Reddit"
  echo ""

  echo "⚠️ Catatan:"
  echo "- Tidak semua konten bisa di-download"
  echo "- Beberapa situs memerlukan login/cookies"
  echo "- Kualitas tergantung sumber platform"
  echo ""

  echo "💡 Tips:"
  echo "- Gunakan MP4 untuk kompatibilitas"
  echo "- Gunakan Best untuk kualitas maksimal"
  echo ""

  read -p "ENTER untuk kembali..."
  ;;
  
  5)
  clear
  echo "=============================="
  echo "   🔍 CEK LINK (ADVANCED)"
  echo "=============================="
  echo ""

  read -p "Masukkan URL: " URL

  echo ""
  echo "🔎 Mengecek..."

  # ===== AMBIL DATA JSON =====
  json=$(yt-dlp --dump-json "$URL" 2>/dev/null)

  if [ -z "$json" ]; then
    echo ""
    echo "❌ Status : Tidak bisa didownload / tidak didukung"
    echo ""
    read -p "ENTER untuk kembali..."
    continue
  fi

  # ===== PARSING DATA =====
  title=$(echo "$json" | grep -o '"title": *"[^"]*"' | head -n1 | cut -d'"' -f4)
  uploader=$(echo "$json" | grep -o '"uploader": *"[^"]*"' | head -n1 | cut -d'"' -f4)
  dur=$(echo "$json" | grep -o '"duration": *[0-9]*' | grep -o '[0-9]*')

  dur=${dur:-0}

  # ===== FALLBACK =====
  [ -z "$title" ] && title="(Tidak tersedia)"
  [ -z "$uploader" ] && uploader="(Tidak tersedia)"

  # ===== PLATFORM =====
  domain=$(echo "$URL" | awk -F/ '{print $3}' | sed 's/www\.//')

  echo ""
  echo "Status   : ✅ Bisa didownload"
  echo "Platform : 🌐 $domain"
  echo "Judul    : 🎬 $title"
  echo "Channel  : 📺 $uploader"
  printf "Durasi   : ⏱️ %02d:%02d:%02d\n" $((dur/3600)) $(((dur%3600)/60)) $((dur%60))

  # ===== FORMAT INFO =====
  echo ""
  echo "📦 Mengambil informasi format..."

  formats=$(yt-dlp -F "$URL" 2>/dev/null)
  ext=$(echo "$json" | grep -o '"ext": *"[^"]*"' | head -n1 | cut -d'"' -f4)

  # ===== RESOLUSI =====
  echo ""
  echo "🎥 Resolusi tersedia:"
  resolutions=$(echo "$formats" | grep -E "^[0-9]" | awk '{print $3}' | grep -E '[0-9]+x[0-9]+' | sort -u)

  if [ -z "$resolutions" ]; then
    echo "- (Format tunggal / tidak tersedia)"
  else
    echo "$resolutions"
  fi

  # ===== CONTAINER =====
  echo ""
  echo "📁 Format tersedia:"

  containers=$(echo "$formats" | grep -E "^[0-9]" | awk '{print $2}' | sort -u)

  if [ -z "$containers" ]; then
    if [ -n "$ext" ]; then
      echo "- $ext"
      containers="$ext"
    else
      echo "- (Tidak terdeteksi)"
    fi
  else
    for c in $containers; do
      echo "- $c"
    done
  fi

  # ===== MP4 CHECK =====
  echo ""
  if echo "$containers" | grep -q "mp4" || [ "$ext" = "mp4" ]; then
    echo "🎯 MP4     : ✅ Tersedia"
  else
    echo "🎯 MP4     : ❌ Tidak tersedia"
  fi

  # ===== PLATFORM INFO =====
  echo ""
  echo "🌐 Info Platform:"
  case "$domain" in
    *youtube*) echo "- Platform besar, banyak resolusi tersedia" ;;
    *tiktok*) echo "- Biasanya hanya 1 kualitas" ;;
    *instagram*) echo "- Biasanya 1 kualitas + tanpa audio terpisah" ;;
    *facebook*) echo "- Kadang butuh login / kualitas terbatas" ;;
    *) echo "- Platform umum / tergantung sumber" ;;
  esac

  # ===== TIPS =====
  echo ""
  echo "💡 Tips:"
  echo "- Gunakan MP4 untuk kompatibilitas"
  echo "- Gunakan Best untuk kualitas maksimal"
  echo "- Jika format terbatas, itu dari platform"
  echo "- Beberapa situs butuh cookies/login"

  echo ""
  read -p "ENTER untuk kembali..."
  ;;

  # =========================
  # UPDATE YT-DLP
  # =========================
  6)
    pip install -U yt-dlp
    echo "✔ Update selesai"
    read -p "ENTER..."
    ;;

  # =========================
  # EXIT
  # =========================
  
  0)
    echo "Keluar..."
    break
    ;;

  *)
    echo "Pilihan tidak valid!"
    read -p "ENTER..."
    ;;

  esac

done
